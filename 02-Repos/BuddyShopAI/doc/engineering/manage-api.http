@baseUrl = https://mrvshop-func.azurewebsites.net/api
@manageKey = ca1ccbf95b4b9b77b58c308986df7a14d0e9738deff9cd5ea6056d5255bd77cc
@userId = U847d644ed4512af217e6b391c6b8c890

# 注意：Azure Functions 保留 "admin" 路由前綴，故此專案統一使用 "manage" 前綴

### 查詢系統狀態
GET {{baseUrl}}/manage/status
X-Manage-Key: {{manageKey}}

### 強制 AI 重新回應指定使用者最後訊息
POST {{baseUrl}}/manage/users/{{userId}}/retry
X-Manage-Key: {{manageKey}}

### 管理員以 AI 身份傳送自訂訊息
POST {{baseUrl}}/manage/users/{{userId}}/push
Content-Type: application/json
X-Manage-Key: {{manageKey}}

{
  "message": "這是管理員推播訊息"
}

### 切換為真人模式
POST {{baseUrl}}/manage/users/{{userId}}/mode
Content-Type: application/json
X-Manage-Key: {{manageKey}}

{
  "mode": "human",
  "note": "切換為真人客服"
}

### 切換為 AI 模式
POST {{baseUrl}}/manage/users/{{userId}}/mode
Content-Type: application/json
X-Manage-Key: {{manageKey}}

{
  "mode": "ai",
  "note": "切換為 AI 模式"
}

### 查詢指定使用者目前的模式
GET {{baseUrl}}/manage/users/{{userId}}/mode
X-Manage-Key: {{manageKey}}

### 列出所有有記錄的使用者模式
GET {{baseUrl}}/manage/users/modes
X-Manage-Key: {{manageKey}}

### 列出最近 N 小時內有互動的使用者
GET {{baseUrl}}/manage/users/recent?hours=48
X-Manage-Key: {{manageKey}}
